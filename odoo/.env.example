# Copy this file to .env and fill in your credentials
# cp .env.example .env

ODOO_URL=https://mycompany.odoo.com
ODOO_DB=mycompany
ODOO_USERNAME=admin@mycompany.com
ODOO_PASSWORD=your_password_or_api_key

# JWT / auth cookie configuration
# For local development, keep SECURE=false and SAMESITE=lax.
# For production over HTTPS, set SECURE=true and SAMESITE=none (requires HTTPS).
SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_TOKEN_TTL_HOURS=24
